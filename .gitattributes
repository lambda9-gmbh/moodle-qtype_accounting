# Files / directories excluded from `git archive` output.
# These are dev tooling and project artefacts that must not ship in the
# Moodle plugin ZIP uploaded to https://moodle.org/plugins.
dev/                      export-ignore
.gitattributes            export-ignore
.gitignore                export-ignore
.phpcs.xml.dist           export-ignore
.phpmd.xml                export-ignore
.idea/                    export-ignore
.claude/                  export-ignore

# German strings are kept in the repo for local testing only.
# Moodle plugins must ship English-only; translations belong in AMOS
# (https://lang.moodle.org). Excluded from the release ZIP.
lang/de/                  export-ignore
