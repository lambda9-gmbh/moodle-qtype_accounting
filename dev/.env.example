# moodle-qtype_accounting Docker Environment Configuration
# Copy this file to .env and adjust values as needed

# Moodle Configuration
MOODLE_VERSION=MOODLE_405_STABLE
PHP_VERSION=8.2
MOODLE_WWWROOT=http://localhost:8080
MOODLE_SSLPROXY=

# Ports
MOODLE_PORT=8080
PHPMYADMIN_PORT=8081

# Selenium ports (only used when running with --profile testing)
SELENIUM_PORT=4444
SELENIUM_VNC_PORT=7900

# Database Configuration
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=moodle
MYSQL_USER=moodle
MYSQL_PASSWORD=moodle_password
